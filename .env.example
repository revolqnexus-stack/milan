# Copy to .env.local and fill in values. Never commit .env.local.

# Neon pooled (Next.js / Drizzle app)
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require

# Neon direct (drizzle-kit push / migrate)
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require

# Optional Neon console reference
NEON_PROJECT_ID=your-project-id
NEON_API_URL=https://ep-xxxx.apirest.REGION.aws.neon.tech/neondb/rest/v1
NEON_AUTH_URL=https://ep-xxxx.neonauth.REGION.aws.neon.tech/neondb/auth

SESSION_SECRET=long-random-string

BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

NEXT_PUBLIC_WHATSAPP_URL=https://wa.me/91XXXXXXXXXX

SEED_ADMIN_ID=your-admin-id
SEED_ADMIN_PASSWORD=change-me-strong-password
