# Neon pooled connection (use -pooler host). Set the same in Vercel → Settings → Environment Variables.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require

# Secret for /admin API (create/list/reset licences). Long random string.
ADMIN_SECRET=change-me-to-a-long-random-string
